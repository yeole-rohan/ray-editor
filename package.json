{
  "name": "@rohanyeole/ray-editor",
  "version": "2.0.3",
  "description": "Lightweight, dependency-free WYSIWYG rich text editor. Free alternative to TinyMCE & CKEditor.",
  "main": "dist/ray-editor.cjs.js",
  "module": "dist/ray-editor.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ray-editor.esm.js",
      "require": "./dist/ray-editor.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/ray-editor.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "dev": "rollup -c rollup.config.mjs -w",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run lint && npm run test:run && npm run build"
  },
  "keywords": [
    "wysiwyg",
    "rich-text-editor",
    "editor",
    "text-editor",
    "content-editable",
    "tinymce-alternative",
    "quill-alternative",
    "ckeditor-alternative",
    "vanilla-js",
    "zero-dependencies"
  ],
  "author": "Rohan Yeole",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yeole-rohan/ray-editor"
  },
  "homepage": "https://github.com/yeole-rohan/ray-editor",
  "bugs": {
    "url": "https://github.com/yeole-rohan/ray-editor/issues"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@vitest/ui": "^1.4.0",
    "jsdom": "^24.0.0",
    "postcss-import": "^16.1.1",
    "rimraf": "^5.0.5",
    "rollup": "^4.12.0",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.6.2",
    "typescript": "^5.4.2",
    "vitest": "^1.4.0"
  },
  "sideEffects": [
    "*.css"
  ]
}
