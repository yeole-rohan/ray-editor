  "license": "MIT",
  "peerDependencies": {
    "vue": ">=3.0.0",
    "ray-editor": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vue": ">=3.0.0"
  }
}
