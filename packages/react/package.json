{
  "name": "@ray-editor/react",
  "version": "2.0.0",
  "description": "React wrapper for RayEditor",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc && rollup -c"
  },
  "keywords": ["ray-editor", "react", "wysiwyg", "rich-text-editor"],
  "author": "Rohan Yeole",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "ray-editor": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": ">=17.0.0",
    "typescript": "^6.0.2"
  }
}
